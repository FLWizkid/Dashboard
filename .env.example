# ─────────────────────────────────────────────────────────────────────────
# God's Master Dashboard — environment template
# Copy this file to `.env.local` and fill in the values.
# NEVER commit `.env.local` or real keys. `.gitignore` already excludes them.
# ─────────────────────────────────────────────────────────────────────────

# Self-hosted Supabase — runs on your Windows/WSL2 box, reachable over Tailscale.
# Use the Tailscale hostname or 100.x.y.z address of that box, e.g.
#   http://your-host.tailnet-name.ts.net:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses Row Level Security — keep OUT of the browser and OUT of git.
# Only read in server-side code; never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
